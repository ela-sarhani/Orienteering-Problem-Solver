# Git ignore for Python project - generated by assistant

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
build/
dist/
*.egg-info/
.eggs/

# Virtual environments
.venv/
venv/
ENV/
env/

# Editor directories and files
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Pytest / testing
.pytest_cache/
.nox/

# Mypy
.mypy_cache/

# Jupyter
.ipynb_checkpoints/

# Env files
.env
.env.*

# Logs and databases
*.log
*.sqlite3

# OS files
.DS_Store
Thumbs.db

# Outputs and generated visualization artifacts
outputs/

# Wheels
*.whl

# Coverage
.coverage
htmlcov/

# Misc
*.bak
*.swp

# End of .gitignore
